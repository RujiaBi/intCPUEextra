PKG_CPPFLAGS = -DTMBAD_FRAMEWORK

all: $(SHLIB) precompile_templates

precompile_templates:
	"$(R_HOME)/bin$(R_ARCH_BIN)/Rscript.exe" -e "library(TMB); src <- normalizePath(getwd(), winslash='/'); tmb_dir <- file.path(src, 'tmb'); out_dir <- file.path(src, '..', 'inst', 'tmb'); dir.create(out_dir, recursive=TRUE, showWarnings=FALSE); stale <- list.files(tmb_dir, pattern='[.](o|obj|dll)$$', full.names=TRUE); if (length(stale) > 0L) unlink(stale, force=TRUE); old <- getwd(); on.exit(setwd(old), add=TRUE); setwd(tmb_dir); files <- c('intCPUE_q00.cpp','intCPUE_q10.cpp','intCPUE_q01.cpp','intCPUE_q11.cpp'); for (f in files) compile(f, openmp=TRUE, framework='TMBad'); dynext <- get('.Platform')[['dynlib.ext']]; dlls <- list.files(tmb_dir, pattern=paste0('[.]', sub('^[.]', '', dynext), '$$'), full.names=TRUE); if (length(dlls) != length(files)) stop('Expected ', length(files), ' template DLLs but found ', length(dlls), '.'); copied <- file.copy(dlls, out_dir, overwrite=TRUE); if (!all(copied)) stop('Failed to copy one or more template DLLs into inst/tmb.')"
